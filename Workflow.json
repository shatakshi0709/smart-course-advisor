    {
      "parameters": {
        "jsCode": "const data = $('Edit Fields').item.json;\n\n// 🔥 USER INPUT yaha se lo\nconst userSubject = ($('Edit Fields1').item.json.Subject || \"\").toLowerCase();\n\nconst categories = Object.keys(data);\n\nlet matchedCategory = null;\n\nfor (const cat of categories) {\n  const cleanCat = cat.toLowerCase();\n\n  if (\n    cleanCat.includes(userSubject) ||\n    userSubject.includes(cleanCat)\n  ) {\n    matchedCategory = cat;\n    break;\n  }\n}\n\nreturn [\n  {\n    json: {\n      userSubject,\n      matchedCategory: matchedCategory || \"No match found\",\n      courses: matchedCategory ? data[matchedCategory].courses : []\n    }\n  }\n];"
      },
